<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource KgvBackground}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource KgvText}" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource KgvText}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource KgvMuted}" />
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource KgvPrimary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>

    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource Button}">
        <Setter Property="BackgroundColor" Value="{StaticResource KgvAccent}" />
        <Setter Property="TextColor" Value="{StaticResource KgvText}" />
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource KgvSurface}" />
        <Setter Property="Stroke" Value="{StaticResource KgvBorder}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="22" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EntryBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="Stroke" Value="{StaticResource KgvBorder}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="14" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ReadOnlyField" TargetType="Border" BasedOn="{StaticResource EntryBorder}">
        <Setter Property="BackgroundColor" Value="#F5F5F5" />
        <Setter Property="Opacity" Value="0.95" />
    </Style>

</ResourceDictionary>
