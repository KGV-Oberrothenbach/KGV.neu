<Window x:Class="KGV.Views.ArbeitsstundeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        Title="Arbeitsstunde">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mitglied:" VerticalAlignment="Center" Margin="0,0,10,0" />
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="MitgliedComboBox"
                  SelectedValuePath="Id">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName, Mode=OneWay}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Datum:" VerticalAlignment="Center" Margin="0,10,10,0" />
        <DatePicker Grid.Row="1" Grid.Column="1" x:Name="DatumPicker" Margin="0,10,0,0" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Saison:" VerticalAlignment="Center" Margin="0,10,10,0" />
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="SaisonComboBox" Margin="0,10,0,0"
                  DisplayMemberPath="Jahr" SelectedValuePath="Id" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Stunden:" VerticalAlignment="Center" Margin="0,10,10,0" />
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="StundenTextBox" Margin="0,10,0,0" />

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Beschreibung:" VerticalAlignment="Top" Margin="0,10,10,0" />
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="BeschreibungTextBox" Margin="0,10,0,0" Height="90" AcceptsReturn="True" TextWrapping="Wrap" />

        <CheckBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" x:Name="FreigegebenCheckBox" Margin="0,12,0,0"
                  Content="Freigegeben" />

        <DockPanel Grid.Row="6" Grid.ColumnSpan="2" Margin="0,15,0,0">
            <Button x:Name="DeleteButton" DockPanel.Dock="Left" Width="110" Content="Löschen" Foreground="DarkRed"
                    Visibility="Collapsed" Click="Delete_Click" />

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Width="100" Margin="0,0,10,0" Content="Abbrechen" IsCancel="True" />
                <Button Width="100" Content="OK" IsDefault="True" Click="Ok_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
