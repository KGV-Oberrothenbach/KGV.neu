<Window x:Class="KGV.Views.DatumDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        Title="Datum wählen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Datum:" VerticalAlignment="Center" Margin="0,0,10,0" />
        <DatePicker Grid.Row="0" Grid.Column="1" x:Name="DatumPicker" />

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Width="100" Margin="0,0,10,0" Content="Abbrechen" IsCancel="True" />
            <Button Width="100" Content="OK" IsDefault="True" Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>
