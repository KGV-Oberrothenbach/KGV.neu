<!-- File: Views/MemberParzellenSection.xaml -->
<UserControl x:Class="KGV.Views.MemberParzellenSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <GroupBox Header="Parzellen" Margin="0,0,0,20">
        <StackPanel Margin="10">

            <DataGrid ItemsSource="{Binding ParzellenBelegungen}"
                      SelectedItem="{Binding SelectedBelegung}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      Height="220">
                <DataGrid.InputBindings>
                    <MouseBinding Gesture="LeftDoubleClick"
                                  Command="{Binding OpenSelectedParzelleCommand}" />
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Garten-Nr" Binding="{Binding GartenNr}" Width="140"/>
                    <DataGridTextColumn Header="Anlage" Binding="{Binding Anlage}" Width="*"/>
                    <DataGridTextColumn Header="Von" Binding="{Binding VonDatum, StringFormat=d}" Width="110"/>
                    <DataGridTextColumn Header="Bis" Binding="{Binding BisDatum, StringFormat=d}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
                <TextBlock Text="Freie Parzelle:" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <!-- ✅ bewusst NICHT an IsEditMode gebunden -->
                <ComboBox Width="220"
                          ItemsSource="{Binding AvailableParzellen}"
                          SelectedItem="{Binding SelectedParzelleToAssign}"
                          DisplayMemberPath="GartenNr"
                          IsEnabled="True"/>

                <TextBlock Text="Start:" VerticalAlignment="Center" Margin="15,0,5,0"/>

                <!-- ✅ überschreibt globalen DatePicker-Style (der sonst IsEditMode erzwingt) -->
                <DatePicker Width="140"
                            SelectedDate="{Binding AssignVonDatum, UpdateSourceTrigger=PropertyChanged}"
                            IsEnabled="True"/>

                <Button Content="Garten zuordnen"
                        Width="150"
                        Height="30"
                        Margin="15,0,0,0"
                        Command="{Binding AssignParzelleCommand}"/>

                <Button Content="Belegung beenden"
                        Width="160"
                        Height="30"
                        Margin="10,0,0,0"
                        Command="{Binding EndBelegungCommand}"/>
            </StackPanel>

        </StackPanel>
    </GroupBox>
</UserControl>