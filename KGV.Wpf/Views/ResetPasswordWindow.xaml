<Window x:Class="KGV.Views.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Passwort zurücksetzen"
        Height="300"
        Width="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8" />
        <TextBlock Grid.Row="1" Text="{Binding Description}" TextWrapping="Wrap" Margin="0,0,0,12" />

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="E-Mail" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <Border Grid.Row="3" Padding="12" Background="{StaticResource KgvSurfaceBrush}" Margin="0,0,0,12">
            <TextBlock Text="{Binding RecoveryHint}" TextWrapping="Wrap" />
        </Border>

        <StackPanel Grid.Row="4">
            <Button Content="Reset-Mail senden" Command="{Binding SendCommand}" Width="180" Height="32" HorizontalAlignment="Left" Style="{StaticResource PrimaryButton}"/>
            <TextBlock Margin="0,12,0,0" Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="DarkSlateBlue"/>
        </StackPanel>
    </Grid>
</Window>
