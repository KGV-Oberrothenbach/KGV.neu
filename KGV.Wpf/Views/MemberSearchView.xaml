<UserControl x:Class="KGV.Views.MemberSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:KGV.Helpers"
             Background="{DynamicResource KgvBackgroundBrush}">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverterLocal x:Key="BoolToVisibilityConverterLocal"/>
        <helpers:FirstNonEmptyConverter x:Key="FirstNonEmptyConverter" />
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="100" />
        </Grid.RowDefinitions>

        <TextBlock Text="Mitgliedersuche" FontSize="18" FontWeight="Bold" />

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,8,0,8">
            <TextBox Width="300" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Suchen" Margin="8,0,0,0" Command="{Binding SearchCommand}" />
            <CheckBox Content="nach Gartennummer suchen"
                      Margin="12,0,0,0"
                      IsChecked="{Binding SearchByParzelle}" />
        </StackPanel>

        <StackPanel Grid.Row="2">
            <ListView x:Name="ResultsListView"
                      ItemsSource="{Binding Results}"
                      SelectedItem="{Binding SelectedResult}"
                      Height="300"
                      MouseDoubleClick="ResultsListView_MouseDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Name" Click="GridViewColumnHeader_Click" Tag="Nachname" />
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource FirstNonEmptyConverter}">
                                                <Binding Path="Name" />
                                                <Binding Path="Nachname" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Vorname" Click="GridViewColumnHeader_Click" Tag="Vorname" />
                            </GridViewColumn.Header>
                            <GridViewColumn.DisplayMemberBinding>
                                <Binding Path="Vorname" />
                            </GridViewColumn.DisplayMemberBinding>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>

        <!-- ⚡ Debug-Output -->
        <ListBox Grid.Row="3"
                 ItemsSource="{Binding DebugMessages}"
                 Height="100"
                 Background="#f0f0f0"/>
    </Grid>
</UserControl>