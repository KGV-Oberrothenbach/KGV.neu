<!-- File: Views/MemberDetailView.xaml -->
<UserControl x:Class="KGV.Views.MemberDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:KGV.Views"
             Background="{DynamicResource KgvBackgroundBrush}">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="IsReadOnly" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DatePicker}" BasedOn="{StaticResource {x:Type DatePicker}}">
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="IsEnabled" Value="True"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="IsEnabled" Value="True"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="IsEnabled" Value="True"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SaveButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="IsEnabled" Value="False"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsEditMode}" Value="True"/>
                        <Condition Binding="{Binding IsDirty}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="IsEnabled" Value="True"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="IsEnabled" Value="False"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="IsEnabled" Value="True"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical">
                <TextBlock Text="Stammdaten"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <!-- Dirty Hinweis -->
                <TextBlock Text="Ungespeicherte Änderungen"
                           Margin="0,6,0,0"
                           FontWeight="SemiBold"
                           Foreground="DarkRed">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Bearbeiten" Width="140" Height="35" Margin="0,0,10,0"
                        Style="{StaticResource EditButtonStyle}" Command="{Binding ToggleEditCommand}"/>
                <Button Content="Speichern" Width="140" Height="35" Margin="0,0,10,0"
                        Style="{StaticResource SaveButtonStyle}" Command="{Binding SaveCommand}"/>
                <Button Content="Abbrechen" Width="140" Height="35" Margin="0,0,10,0"
                        Style="{StaticResource CancelButtonStyle}" Command="{Binding CancelCommand}"/>

                <Button Width="200" Height="35" Margin="0,0,10,0"
                        Content="{Binding NebenmitgliedButtonText}"
                        Visibility="{Binding ShowNebenmitgliedButton, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding NebenmitgliedCommand}" />

                <Button Content="Adresse übernehmen" Width="200" Height="35" Margin="0,0,10,0"
                        Visibility="{Binding ShowAdresseUebernehmenButton, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding CopyAddressFromHauptmitgliedCommand}" />

                <Button Content="Neuer Pachtvertrag" Width="200" Height="35"
                        Visibility="{Binding ShowNewContractButton, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding NewContractCommand}"/>
            </StackPanel>
        </Grid>

        <!-- FORMULAR -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <GroupBox Header="Persönliche Daten" Margin="0,0,0,20">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="5">
                            <TextBlock Text="Nachname"/>
                            <TextBox Text="{Binding SelectedMember.Nachname, UpdateSourceTrigger=PropertyChanged}" MinWidth="200"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5">
                            <TextBlock Text="Vorname"/>
                            <TextBox Text="{Binding SelectedMember.Vorname, UpdateSourceTrigger=PropertyChanged}" MinWidth="200"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="5">
                            <TextBlock Text="Geburtsdatum"/>
                            <DatePicker SelectedDate="{Binding SelectedMember.Geburtsdatum, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Adresse" Margin="0,0,0,20">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="5">
                            <TextBlock Text="Straße / Hausnummer"/>
                            <TextBox Text="{Binding SelectedMember.Strasse, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="PLZ"/>
                                <TextBox Grid.Row="1" Text="{Binding SelectedMember.PLZ, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                            </Grid>

                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Text="Ort"/>
                                <TextBox Text="{Binding SelectedMember.Ort, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Kontakt" Margin="0,0,0,20">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                            <TextBlock Text="Telefon"/>
                            <TextBox Text="{Binding SelectedMember.Telefon, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                            <TextBlock Text="Mobilnummer"/>
                            <TextBox Text="{Binding SelectedMember.Mobilnummer, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="5">
                            <TextBlock Text="WhatsApp"/>
                            <CheckBox Content="Einwilligung" IsChecked="{Binding SelectedMember.WhatsappEinwilligung, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="5">
                            <TextBlock Text="E-Mail"/>
                            <TextBox Text="{Binding SelectedMember.Email, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Mitgliedschaft" Margin="0,0,0,20">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="5">
                            <TextBlock Text="Mitglied seit"/>
                            <DatePicker SelectedDate="{Binding SelectedMember.MitgliedSeit, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="20,5" VerticalAlignment="Bottom">
                            <CheckBox Content="Aktiv" IsChecked="{Binding SelectedMember.Aktiv, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="5">
                            <TextBlock Text="Mitglied Ende"/>
                            <DatePicker SelectedDate="{Binding SelectedMember.MitgliedEnde, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- ✅ Parzellen-Section -->
                <views:MemberParzellenSection Visibility="{Binding ShowParzellenSection, Converter={StaticResource BoolToVisibility}}"/>

                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <Button Content="Mitgliedschaft beenden" Width="220" Height="35" Command="{Binding CancelMembershipCommand}"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>