<Window x:Class="KGV.Views.ChangeEmailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="E-Mail ändern"
        Height="260"
        Width="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12" />
            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,0,0,12" />
            <Border Padding="12" Background="{StaticResource KgvSurfaceBrush}">
                <TextBlock Text="{Binding RecoveryHint}" TextWrapping="Wrap" />
            </Border>
        </StackPanel>
    </Grid>
</Window>
