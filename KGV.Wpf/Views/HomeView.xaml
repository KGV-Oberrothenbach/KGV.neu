<UserControl x:Class="KGV.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,0,0,8" />
            <Border Padding="12" Background="{StaticResource KgvSurfaceBrush}">
                <TextBlock Text="{Binding UserContextText}" TextWrapping="Wrap" />
            </Border>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding QuickLinksTitle}" FontWeight="SemiBold" Margin="0,0,0,12" />

                <ItemsControl ItemsSource="{Binding QuickLinks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.OpenModuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Margin="0,0,0,8"
                                    MinHeight="52"
                                    HorizontalContentAlignment="Left">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="11" Foreground="Gray"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="DarkSlateBlue"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Margin="24,0,0,0"
                    Padding="16"
                    Background="{StaticResource KgvSurfaceBrush}"
                    BorderBrush="{StaticResource KgvBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="{Binding OperationalTitle}" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <ItemsControl ItemsSource="{Binding OperationalItems}"
                                  Visibility="{Binding HasOperationalItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="12"
                                        Background="{StaticResource KgvBackgroundBrush}"
                                        BorderBrush="{StaticResource KgvBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{Binding OperationalEmptyText}"
                               TextWrapping="Wrap"
                               Visibility="{Binding ShowOperationalEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Margin="24,0,0,0"
                    Padding="16"
                    Background="{StaticResource KgvSurfaceBrush}"
                    BorderBrush="{StaticResource KgvBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding AnnouncementTitle}" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <ListBox ItemsSource="{Binding Announcements}"
                                 SelectedItem="{Binding SelectedAnnouncement, Mode=TwoWay}"
                                 DisplayMemberPath="Title"
                                 Visibility="{Binding HasAnnouncements, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 BorderThickness="0"
                                 MinHeight="80" />
                        <TextBlock Text="{Binding AnnouncementEmptyText}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding ShowAnnouncementEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                Visibility="{Binding HasAnnouncements, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Detail" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <TextBlock Text="{Binding SelectedAnnouncement.Title}"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   Visibility="{Binding HasSelectedAnnouncement, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding HasSelectedAnnouncement, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding SelectedAnnouncement.Content}" TextWrapping="Wrap" Margin="0,8,0,0" />
                        </ScrollViewer>

                        <TextBlock Text="{Binding AnnouncementHintText}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding ShowAnnouncementHint, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
