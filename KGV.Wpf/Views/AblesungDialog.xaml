<Window x:Class="KGV.Views.AblesungDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        Title="Ablesung">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="260" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ablesedatum:" VerticalAlignment="Center" Margin="0,0,10,0" />
        <DatePicker Grid.Row="0" Grid.Column="1" x:Name="AblesedatumPicker" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Zählerstand:" VerticalAlignment="Center" Margin="0,10,10,0" />
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="StandTextBox" Margin="0,10,0,0" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Foto (Link):" VerticalAlignment="Center" Margin="0,10,10,0" />
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="FotoTextBox" Margin="0,10,0,0" />

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Width="100" Margin="0,0,10,0" Content="Abbrechen" IsCancel="True" />
            <Button Width="100" Content="OK" IsDefault="True" Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>
